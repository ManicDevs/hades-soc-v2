{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode.ai/config.json",
  "title": "HADES-V2 OpenCode Configuration",
  "description": "Configuration for HADES-V2 development workflow",
  "type": "object",
  "properties": {
    "model": {
      "type": "string",
      "description": "AI model to use"
    },
    "instructions": {
      "type": "array",
      "description": "Instruction files",
      "items": {
        "type": "string"
      }
    },
    "agents": {
      "type": "object",
      "description": "Agent configurations",
      "properties": {
        "hades-agent": {
          "type": "object",
          "description": "HADES agent configuration",
          "properties": {
            "name": {
              "type": "string",
              "description": "Agent name"
            },
            "instructions": {
              "type": "string",
              "description": "Agent instructions"
            }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "description": "Permission settings",
      "properties": {
        "git": {
          "type": "string",
          "description": "Git permission level"
        },
        "file_delete": {
          "type": "string",
          "description": "File deletion permission level"
        }
      }
    },
    "workflow": {
      "type": "object",
      "description": "Workflow configuration",
      "properties": {
        "agents_path": {
          "type": "string",
          "description": "Path to agents directory"
        },
        "commands_path": {
          "type": "string",
          "description": "Path to commands directory"
        },
        "pm_agent": {
          "type": "string",
          "description": "Project manager agent"
        },
        "check_agent": {
          "type": "string",
          "description": "Code checking agent"
        },
        "test_agent": {
          "type": "string",
          "description": "Testing agent"
        },
        "make_agent": {
          "type": "string",
          "description": "Build system agent"
        }
      }
    },
    "server": {
      "type": "object",
      "description": "Server configuration",
      "properties": {
        "host": {
          "type": "string",
          "description": "Server host"
        },
        "port": {
          "type": "integer",
          "description": "Server port"
        }
      }
    },
    "autonomy": {
      "type": "object",
      "description": "Autonomy settings",
      "properties": {
        "max_retries": {
          "type": "integer",
          "description": "Maximum retry attempts"
        },
        "continue_on_warning": {
          "type": "boolean",
          "description": "Continue on warning"
        },
        "escalate_on_max_retries": {
          "type": "boolean",
          "description": "Escalate on max retries"
        }
      }
    }
  },
  "required": ["model", "instructions", "agents"]
}
