# AI Provider API Keys
# ====================

# Groq - Fastest free tier (30 RPM, 6K TPM)
# https://console.groq.com/keys
GROQ_API_KEY=

# HuggingFace - Good variety (100 RPM, 100K TPM)
# https://huggingface.co/settings/inference-endpoints
HUGGINGFACE_API_KEY=

# Cohere - Highest RPM limit (1000 RPM, 2M TPM)
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Cloudflare Workers AI - High TPM (300 RPM, 10M TPM)
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# OpenRouter - Model variety (requires credits for free models)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===== Paid / Limited APIs =====

# Anthropic - No free tier, needs credits
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI - Limited free tier
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini - Rate limited free tier
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# TogetherAI - Limited free credits
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=