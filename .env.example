# Hades SOC V2.0 Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env files with real secrets to version control

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Node.js environment (for frontend)
NODE_ENV=development

# Enable development access features
ENABLE_DEV_ACCESS=true

# Require authentication for API access
REQUIRE_AUTHENTICATION=false

# Enable multi-factor authentication
ENABLE_MFA=false

# Session timeout in seconds
SESSION_TIMEOUT=7200

# Application logging level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable debug logging
ENABLE_DEBUG_LOGGING=true

# Enable user registration
ENABLE_REGISTRATION=true

# Enable password reset functionality
ENABLE_PASSWORD_RESET=true

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# SERVICE PORTS
# ===========================================

# Web frontend port
WEB_PORT=3000

# API service port
API_PORT=8443

# Authentication service port
AUTH_PORT=8444

# Dashboard service port
DASHBOARD_PORT=8445

# Sentinel monitoring port
SENTINEL_PORT=2112

# Hades API port
HADES_API_PORT=8081

# Uptime Kuma monitoring port
UPTIME_KUMA_PORT=3001

# PostgreSQL database port
POSTGRES_PORT=5432

# PostgreSQL database port (alternative)
POSTGRES_DB_PORT=5432

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Database connection URL (format: postgresql://user:password@host:port/database?sslmode=mode)
DATABASE_URL=postgresql://hades:password@localhost:5432/hades_db?sslmode=disable

# PostgreSQL SSL mode (disable, require, verify-ca, verify-full)
POSTGRES_SSL=disable

# PostgreSQL host
POSTGRES_HOST=localhost

# PostgreSQL database name
POSTGRES_DB=hades_db

# PostgreSQL username
POSTGRES_USER=hades

# PostgreSQL password
POSTGRES_PASSWORD=your_secure_password_here

# ===========================================
# AUTHENTICATION & ENCRYPTION
# ===========================================

# JWT secret key for token signing (use a strong random string)
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# Application encryption key (use a strong random string)
ENCRYPTION_KEY=your_encryption_key_minimum_32_characters

# API key for external integrations
API_KEY=your_api_key_here

# Secret key for internal services
SECRET_KEY=your_secret_key_here

# ===========================================
# NETWORK & INFRASTRUCTURE
# ===========================================

# Internal network subnet
INTERNAL_NETWORK_SUBNET=172.28.0.0/16

# Internal network gateway
INTERNAL_NETWORK_GATEWAY=172.28.0.1

# Redis connection URL (if using Redis)
REDIS_URL=redis://localhost:6379

# Kafka brokers (comma-separated, if using Kafka)
KAFKA_BROKERS=localhost:9092

# Elasticsearch URL (if using Elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200

# ===========================================
# SIEM INTEGRATIONS
# ===========================================

# SIEM endpoint URL
SIEM_ENDPOINT=https://your-siem.example.com/api/events

# Tailscale authentication key (optional)
TAILSCALE_AUTHKEY=tskey-auth-your-tailscale-key-here

# ===========================================
# DEVELOPMENT & BUILD
# ===========================================

# Build version
VERSION=v2.0

# Build timestamp (auto-generated)
BUILD_TIME=2024-01-01T00:00:00Z

# ===========================================
# SECURITY SETTINGS
# ===========================================

# Environment suffix for security contexts
ENV_SUFFIX=prod

# Gin framework mode (debug, release, test)
GIN_MODE=release

# Enable seccomp security profile
ENABLE_SECCOMP=true

# Use read-only filesystem
READ_ONLY_FILESYSTEM=true

# Run as non-root user
NON_ROOT_USER=true

# Seccomp profile file path
SECCOMP_PROFILE=seccomp-default.json

# Container restart policy
RESTART_POLICY=unless-stopped
