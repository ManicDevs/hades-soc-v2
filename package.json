{
  "name": "hades-v2",
  "version": "2.0.0",
  "description": "Hades-V2 Enterprise Security Framework",
  "private": true,
  "scripts": {
    "build": "go build -o hades ./cmd/hades",
    "test": "go test -v -race ./...",
    "test:integration": "go test -v -race -tags=integration ./tests/integration/...",
    "lint": "go vet ./...",
    "format": "gofmt -s -l .",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "web:test": "cd web && npm run test:unit",
    "web:test:e2e": "cd web && npm run test:e2e",
    "docker:build": "docker build -t hades-v2 .",
    "docker:run": "docker-compose up -d"
  },
  "dependencies": {},
  "devDependencies": {}
}
