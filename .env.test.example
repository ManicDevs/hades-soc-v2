# Hades SOC V2.0 Test Environment
# Copy this file to .env.test for testing configuration

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application environment
ENVIRONMENT=test
NODE_ENV=test

# Enable development access features for testing
ENABLE_DEV_ACCESS=true

# Require authentication for API access (test: can be false for unit tests)
REQUIRE_AUTHENTICATION=false

# Enable multi-factor authentication (test: false)
ENABLE_MFA=false

# Session timeout in seconds (test: short for automated tests)
SESSION_TIMEOUT=300

# Application logging level (test: debug for test visibility)
LOG_LEVEL=debug

# Enable debug logging
ENABLE_DEBUG_LOGGING=true

# Enable user registration (test: true for test users)
ENABLE_REGISTRATION=true

# Enable password reset functionality
ENABLE_PASSWORD_RESET=true

# Enable audit logging (test: true for audit trail)
ENABLE_AUDIT_LOGGING=true

# CORS allowed origins (test: localhost)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# SERVICE PORTS (Test)
# ===========================================

# Use different ports for testing to avoid conflicts
WEB_PORT=3001
API_PORT=8446
AUTH_PORT=8447
DASHBOARD_PORT=8448
SENTINEL_PORT=2113
HADES_API_PORT=8082
UPTIME_KUMA_PORT=3002
POSTGRES_PORT=5433

# ===========================================
# DATABASE CONFIGURATION (Test)
# ===========================================

# Test database connection (in-memory or test database)
DATABASE_URL=postgresql://hades_test:test_password@localhost:5433/hades_test?sslmode=disable

# PostgreSQL settings (test)
POSTGRES_SSL=disable
POSTGRES_HOST=localhost
POSTGRES_DB=hades_test
POSTGRES_USER=hades_test
POSTGRES_PASSWORD=test_password

# ===========================================
# AUTHENTICATION & ENCRYPTION (Test)
# ===========================================

# Test JWT secret (change for production!)
JWT_SECRET=test_jwt_secret_key_minimum_32_characters_long

# Test encryption key (change for production!)
ENCRYPTION_KEY=test_encryption_key_minimum_32_characters

# Test API key
API_KEY=test_api_key

# Test secret key
SECRET_KEY=test_secret_key

# ===========================================
# NETWORK & INFRASTRUCTURE (Test)
# ===========================================

INTERNAL_NETWORK_SUBNET=172.29.0.0/16
INTERNAL_NETWORK_GATEWAY=172.29.0.1

# External services (test: mock or localhost)
# REDIS_URL=redis://localhost:6380
# KAFKA_BROKERS=localhost:9093
# ELASTICSEARCH_URL=http://localhost:9201
# SIEM_ENDPOINT=https://test-siem.example.com/api/events
# TAILSCALE_AUTHKEY=tskey-auth-test-key-here

# ===========================================
# DEVELOPMENT & BUILD
# ===========================================

VERSION=v2.0-test
BUILD_TIME=2024-01-01T00:00:00Z
ENV_SUFFIX=test
GIN_MODE=test

# ===========================================
# SECURITY SETTINGS (Test)
# ===========================================

# Security contexts
ENV_SUFFIX=test

# Test security settings (more permissive for testing)
ENABLE_SECCOMP=false
READ_ONLY_FILESYSTEM=false
NON_ROOT_USER=false
SECCOMP_PROFILE=seccomp-default.json
RESTART_POLICY=unless-stopped
