# Hades SOC V2.0 Development Environment
# Copy this file to .env.dev for development configuration

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application environment
ENVIRONMENT=development
NODE_ENV=development

# Enable development access features
ENABLE_DEV_ACCESS=true

# Require authentication for API access (set to false for development)
REQUIRE_AUTHENTICATION=false

# Enable multi-factor authentication (development: false)
ENABLE_MFA=false

# Session timeout in seconds (development: longer for debugging)
SESSION_TIMEOUT=7200

# Application logging level
LOG_LEVEL=debug

# Enable debug logging
ENABLE_DEBUG_LOGGING=true

# Enable user registration
ENABLE_REGISTRATION=true

# Enable password reset functionality
ENABLE_PASSWORD_RESET=true

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# CORS allowed origins (development: localhost ports)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ===========================================
# SERVICE PORTS (Development)
# ===========================================

WEB_PORT=3000
API_PORT=8443
AUTH_PORT=8444
DASHBOARD_PORT=8445
SENTINEL_PORT=2112
HADES_API_PORT=8081
UPTIME_KUMA_PORT=3001
POSTGRES_PORT=5432

# ===========================================
# DATABASE CONFIGURATION (Development)
# ===========================================

# Development database connection
DATABASE_URL=postgresql://hades:dev_password@localhost:5432/hades_dev?sslmode=disable

# PostgreSQL settings
POSTGRES_SSL=disable
POSTGRES_HOST=localhost
POSTGRES_DB=hades_dev
POSTGRES_USER=hades
POSTGRES_PASSWORD=dev_password

# ===========================================
# AUTHENTICATION & ENCRYPTION (Development)
# ===========================================

# Development JWT secret (change in production!)
JWT_SECRET=dev_jwt_secret_key_change_in_production_minimum_32_characters

# Development encryption key (change in production!)
ENCRYPTION_KEY=dev_encryption_key_change_in_production_minimum_32_characters

# Development API key
API_KEY=dev_api_key_change_in_production

# Development secret key
SECRET_KEY=dev_secret_key_change_in_production

# ===========================================
# NETWORK & INFRASTRUCTURE (Development)
# ===========================================

INTERNAL_NETWORK_SUBNET=172.28.0.0/16
INTERNAL_NETWORK_GATEWAY=172.28.0.1

# Optional external services (comment out if not used)
# REDIS_URL=redis://localhost:6379
# KAFKA_BROKERS=localhost:9092
# ELASTICSEARCH_URL=http://localhost:9200
# SIEM_ENDPOINT=https://dev-siem.example.com/api/events
# TAILSCALE_AUTHKEY=tskey-auth-dev-key-here

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

VERSION=v2.0-dev
BUILD_TIME=2024-01-01T00:00:00Z
ENV_SUFFIX=dev
GIN_MODE=debug

# Security settings (development: more permissive)
ENABLE_SECCOMP=false
READ_ONLY_FILESYSTEM=false
NON_ROOT_USER=false
SECCOMP_PROFILE=seccomp-default.json
RESTART_POLICY=unless-stopped
