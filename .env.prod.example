# Hades SOC V2.0 Production Environment
# Copy this file to .env.prod for production configuration
# Ensure all secrets are strong and properly secured

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application environment
ENVIRONMENT=production
NODE_ENV=production

# Disable development access features in production
ENABLE_DEV_ACCESS=false

# Require authentication for API access (production: true)
REQUIRE_AUTHENTICATION=true

# Enable multi-factor authentication (production: true)
ENABLE_MFA=true

# Session timeout in seconds (production: shorter for security)
SESSION_TIMEOUT=1800

# Application logging level (production: info or warn)
LOG_LEVEL=info

# Disable debug logging in production
ENABLE_DEBUG_LOGGING=false

# Disable user registration in production (use manual provisioning)
ENABLE_REGISTRATION=false

# Enable password reset functionality
ENABLE_PASSWORD_RESET=true

# Enable audit logging (production: true)
ENABLE_AUDIT_LOGGING=true

# CORS allowed origins (production: specific domains only)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ===========================================
# SERVICE PORTS (Production)
# ===========================================

# Use standard ports in production
WEB_PORT=443
API_PORT=8443
AUTH_PORT=8444
DASHBOARD_PORT=8445
SENTINEL_PORT=2112
HADES_API_PORT=8081
UPTIME_KUMA_PORT=3001
POSTGRES_PORT=5432

# ===========================================
# DATABASE CONFIGURATION (Production)
# ===========================================

# Production database connection (use strong password)
DATABASE_URL=postgresql://hades_prod:STRONG_PASSWORD_HERE@prod-db.internal:5432/hades_prod?sslmode=require

# PostgreSQL settings (production: secure)
POSTGRES_SSL=require
POSTGRES_HOST=prod-db.internal
POSTGRES_DB=hades_prod
POSTGRES_USER=hades_prod
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE_CHANGE_ME

# ===========================================
# AUTHENTICATION & ENCRYPTION (Production)
# ===========================================

# Production JWT secret (use a strong random 64+ character string)
JWT_SECRET=PROD_JWT_SECRET_MINIMUM_64_CHARACTERS_LONG_RANDOM_STRING_CHANGE_ME

# Production encryption key (use a strong random 64+ character string)
ENCRYPTION_KEY=PROD_ENCRYPTION_KEY_MINIMUM_64_CHARACTERS_LONG_RANDOM_STRING_CHANGE_ME

# Production API key
API_KEY=PROD_API_KEY_CHANGE_ME

# Production secret key
SECRET_KEY=PROD_SECRET_KEY_CHANGE_ME

# ===========================================
# NETWORK & INFRASTRUCTURE (Production)
# ===========================================

INTERNAL_NETWORK_SUBNET=10.0.0.0/16
INTERNAL_NETWORK_GATEWAY=10.0.0.1

# External services (production: actual endpoints)
REDIS_URL=redis://redis-cluster.internal:6379
KAFKA_BROKERS=kafka-cluster.internal:9092,kafka-cluster.internal:9093
ELASTICSEARCH_URL=https://elasticsearch.internal:9200
SIEM_ENDPOINT=https://siem.internal.com/api/events
TAILSCALE_AUTHKEY=tskey-auth-PROD_TAILSCALE_KEY_CHANGE_ME

# ===========================================
# DEVELOPMENT & BUILD
# ===========================================

VERSION=v2.0
BUILD_TIME=2024-01-01T00:00:00Z
ENV_SUFFIX=prod
GIN_MODE=release

# ===========================================
# SECURITY SETTINGS (Production)
# ===========================================

# Security contexts
ENV_SUFFIX=prod

# Production security settings
ENABLE_SECCOMP=true
READ_ONLY_FILESYSTEM=true
NON_ROOT_USER=true
SECCOMP_PROFILE=seccomp-default.json
RESTART_POLICY=unless-stopped
