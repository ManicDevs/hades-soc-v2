# Testing Environment Configuration
NODE_ENV=testing
ENVIRONMENT=testing
API_BASE_URL=http://localhost:8443
WEB_PORT=3001
API_PORT=8444
AUTH_PORT=8445
DASHBOARD_PORT=8446

# Security Settings
ENABLE_DEV_ACCESS=true
REQUIRE_AUTHENTICATION=false
ENABLE_MFA=false
SESSION_TIMEOUT=999999

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hades_testing
DB_USER=hades_test_user
DB_PASSWORD=test_password

# Logging
LOG_LEVEL=debug
ENABLE_DEBUG_LOGGING=true

# Features
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_AUDIT_LOGGING=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5174

# Testing Configuration
ENABLE_TEST_DATA=true
ENABLE_MOCK_APIS=true
ENABLE_PERFORMANCE_MONITORING=false
ENABLE_SEED_DATA=true
CLEAN_DB_ON_START=true

# Test Users
TEST_USERS_ENABLED=true
TEST_USER_ROLES=admin,user,auditor,operator,developer
