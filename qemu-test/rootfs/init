#!/bin/busybox sh
# HADES Toolkit SOC — Init (PID 1)
# Never exits: restarts hades shell, falls back to ash, loops forever.

# ── Mount essential virtual filesystems ───────────────────────────────────────
/bin/busybox mount -t devtmpfs devtmpfs /dev 2>/dev/null || \
    /bin/busybox mdev -s 2>/dev/null || true
/bin/busybox mount -t proc proc /proc
/bin/busybox mount -t sysfs sysfs /sys
/bin/busybox mkdir -p /dev/pts
/bin/busybox mount -t devpts devpts /dev/pts 2>/dev/null || true

# ── Ensure console devices exist ─────────────────────────────────────────────
[ -c /dev/null ]    || /bin/busybox mknod /dev/null    c 1 3
[ -c /dev/console ] || /bin/busybox mknod /dev/console c 5 1
[ -c /dev/tty ]     || /bin/busybox mknod /dev/tty     c 5 0
[ -c /dev/ttyS0 ]   || /bin/busybox mknod /dev/ttyS0   c 4 64

# ── System identity ───────────────────────────────────────────────────────────
/bin/busybox hostname hades-soc

# ── Networking (best-effort DHCP — does not block boot) ──────────────────────
for iface in eth0 ens3 enp1s0 enp2s0; do
    if /bin/busybox ip link show "$iface" >/dev/null 2>&1; then
        /bin/busybox ip link set "$iface" up 2>/dev/null || true
        /bin/busybox udhcpc -i "$iface" -t 5 -T 3 -n -q 2>/dev/null || true
        break
    fi
done

# ── Load API keys ─────────────────────────────────────────────────────────────
for _env in /etc/hades/keys.env /mnt/keys.env /root/.env; do
    [ -r "$_env" ] && . "$_env" 2>/dev/null || true
done

# ── Helper: run one process on ttyS0 with a proper session ───────────────────
run_on_tty() {
    /bin/busybox setsid /bin/busybox cttyhack "$@" \
        </dev/ttyS0 >/dev/ttyS0 2>/dev/ttyS0
}

# ── Main loop — PID 1 never exits ────────────────────────────────────────────
while true; do

    # Primary: Hades Toolkit SOC interactive terminal
    run_on_tty /bin/hades shell

    # Hades shell exited (user typed 'exit'/'quit') — drop to recovery shell
    /bin/busybox echo "" >/dev/ttyS0
    /bin/busybox echo "┌─────────────────────────────────────────────────────┐" >/dev/ttyS0
    /bin/busybox echo "│  Hades Toolkit SOC — OS Recovery Shell             │" >/dev/ttyS0
    /bin/busybox echo "│  Type 'hades shell'  to return to the SOC terminal  │" >/dev/ttyS0
    /bin/busybox echo "│  Type 'poweroff'     to shut down the system        │" >/dev/ttyS0
    /bin/busybox echo "└─────────────────────────────────────────────────────┘" >/dev/ttyS0
    /bin/busybox echo "" >/dev/ttyS0

    # Recovery: plain busybox ash shell
    run_on_tty /bin/busybox sh

    # If ash also exits, loop back and restart the Hades terminal
    /bin/busybox echo "[init] Restarting Hades Toolkit SOC..." >/dev/ttyS0
    /bin/busybox sleep 1

done
