# HADES-V2 Production Kernel Configuration
# Based on kernel-config-minimal with debug and developer options disabled.

# Minimal base
CONFIG_LOCALVERSION="-hades"
CONFIG_DEFAULT_HOSTNAME="hades"

CONFIG_POSIX_MQUEUE=y
CONFIG_AUDIT=y

# Memory protection
CONFIG_DEFAULT_MMAP_MIN_ADDR=65536
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y

# Kernel hardening
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_YAMA=y
CONFIG_LOCK_DOWN_KERNEL=y
CONFIG_SECURITY_LOCKDOWN_LSM=y

# Core crypto (keep important ones)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_CHACHA20_POLY1305=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_ECHAINIV=y
CONFIG_CRYPTO_SEQIV=y
CONFIG_CRYPTO_AUTHENC=y

# Required crypto helpers
CONFIG_CRYPTO_CBC=y
CONFIG_CRYPTO_CTR=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_PCRYPT=y
CONFIG_CRYPTO_DEFLATE=y

# Post-quantum crypto
CONFIG_CRYPTO_KYBER=y
CONFIG_CRYPTO_DILITHIUM=y

# Random
CONFIG_RANDOM_TRUST_CPU=y
CONFIG_RANDOM_TRUST_BOOTLOADER=y
CONFIG_JUMP_LABEL=y

# Minimal networking
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_CUBIC=y

# Firewall essentials
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_NF_CONNTRACK_IPV6=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y

# IPv6 firewall
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y

# Virtual networking (containers)
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_DUMMY=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Process isolation
CONFIG_CGROUPS=y
CONFIG_CGROUP_NS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_CPUACCT=y

# BPF
CONFIG_BPF_SYSCALL=y
CONFIG_BPF=y
CONFIG_BPF_JIT=y
CONFIG_BPF_LSM=y

# Filesystems (minimal)
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_CONFIGFS_FS=y

# Required for /dev
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Core devices
CONFIG_BLK_DEV=y
CONFIG_BLOCK=y
CONFIG_SCSI=y
CONFIG_ATA=y
CONFIG_NVME=y
CONFIG_VIRTIO_BLK=y

# Network devices (common)
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_VIRTIO_NET=y
CONFIG_PCNET32=y

# Virtio
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_CONSOLE=y

# Console
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y

# CPU features
CONFIG_X86=y
CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_MAXSMP=4

# Memory
CONFIG_ZONE_DMA=y
CONFIG_KSM=y

# ACPI/Power
CONFIG_ACPI=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_HZ=250

# Production: reduce debug footprint
# Keep magic sysrq off in production
# CONFIG_MAGIC_SYSRQ is not set
# Keep BUG handling minimal
CONFIG_BUG=y

# Kernel compression
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=y
CONFIG_RD_LZMA=y
CONFIG_RD_XZ=y
CONFIG_RD_LZO=y
CONFIG_RD_LZ4=y

# Initrd
CONFIG_INITRAMFS_SOURCE=""
